APP_NAME=Rebyu BKT Service
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=false
API_PREFIX=/api/v1/bkt
SERVICE_API_KEY=replace-with-a-long-random-internal-key
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

DATABASE_URL=postgresql+psycopg://rebyu:rebyu@postgres:5432/rebyu
SQL_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_TASK_ALWAYS_EAGER=false
TIMEZONE=Asia/Manila
SCHEDULED_RETRAINING_ENABLED=true
SCHEDULED_RETRAINING_DAY_OF_WEEK=sun
SCHEDULED_RETRAINING_HOUR=2
SCHEDULED_RETRAINING_MINUTE=0

ARTIFACT_DIR=/app/artifacts
TRAINING_VIEW_NAME=rebyu_bkt_training_data_v
MAX_UPLOAD_MB=100

BKT_SEED=42
BKT_NUM_FITS=2
BKT_TEST_SIZE=0.20
BKT_MIN_INTERACTIONS_PER_SKILL=20
BKT_MIN_LEARNERS_PER_SKILL=3

FALLBACK_PRIOR=0.30
FALLBACK_LEARN=0.20
FALLBACK_GUESS=0.25
FALLBACK_SLIP=0.10
FALLBACK_FORGET=0.00

DEVELOPING_THRESHOLD=0.40
GOOD_THRESHOLD=0.70
MASTERED_THRESHOLD=0.85

READINESS_MASTERY_WEIGHT=0.60
READINESS_DIAGNOSTIC_WEIGHT=0.05
READINESS_QUIZ_WEIGHT=0.15
READINESS_MIDDLE_EXAM_WEIGHT=0.10
READINESS_MOCK_EXAM_WEIGHT=0.10

# Priority scoring (lesson component weights; normalized when a component is absent)
PRIORITY_WEIGHT_MASTERY=0.45
PRIORITY_WEIGHT_INCORRECT=0.20
PRIORITY_WEIGHT_MOCK=0.10
PRIORITY_WEIGHT_DIAGNOSTIC=0.10
PRIORITY_WEIGHT_CURRICULUM=0.10
PRIORITY_WEIGHT_REVIEW=0.05

# Priority tag thresholds (0..100)
PRIORITY_CRITICAL_THRESHOLD=85
PRIORITY_HIGH_THRESHOLD=70
PRIORITY_MEDIUM_THRESHOLD=50
PRIORITY_LOW_THRESHOLD=30
PRIORITY_ON_TRACK_THRESHOLD=15

# Mastery safeguards + stabilization hysteresis
PRIORITY_MIN_EVIDENCE=1
MASTERY_CRITICAL_CEILING=0.20
MASTERY_HIGH_CEILING=0.30
PRIORITY_WORSEN_MARGIN=5
PRIORITY_IMPROVE_MARGIN=8

# IMPORTANT: keep this service on its OWN database (the default). The main Rebyu
# Neon DB already owns a table named learner_lesson_mastery (progress package);
# pointing DATABASE_URL at that DB would collide. If you must share one database,
# create the BKT tables in a dedicated "bkt" schema instead of public.
